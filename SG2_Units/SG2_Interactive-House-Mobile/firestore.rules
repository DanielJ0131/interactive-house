rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerUserDoc(userId) {
      return isSignedIn()
        && (
          request.auth.uid == userId
          || request.auth.token.email == userId
        );
    }

    function isAdminByUserId(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn() && (
        isAdminByUserId(request.auth.uid)
        || (
          request.auth.token.email != null
          && isAdminByUserId(request.auth.token.email)
        )
      );
    }

    // Shared device states for the house controller.
    match /devices/{deviceId} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to read melodies.
    match /music/{melodyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Keep user profile docs private to their own account.
    match /users/{userId} {
      allow read, write: if isOwnerUserDoc(userId);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // Shared device state for the Arduino house controller.
    match /devices/arduino {
      allow read, write: if isSignedIn();
    }

    // Keep user profile docs private to their own account.
    match /users/{email} {
      allow read, write: if isOwnerByEmail(email);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}